#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage: github-governance-import-ci plan|apply

Runs a GitHub governance import-block plan in CI. Company-agnostic: the
governance root config comes from $GOVERNANCE_ROOT_CONFIG. The apply mode
is only for the protected workflow_dispatch path and refuses any non-import
resource action.
USAGE
}

require_env() {
  local name="$1"
  if [ -z "${!name:-}" ]; then
    echo "::error::${name} is required." >&2
    exit 1
  fi
}

mode="${1:-}"
case "$mode" in
  plan | apply) ;;
  *)
    usage
    exit 2
    ;;
esac

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
workspace="${GITHUB_WORKSPACE:-$root}"

require_env GOVERNANCE_ROOT
require_env GOVERNANCE_RESULT_ROOT
require_env BACKEND_CONFIG_FILE
require_env GOVERNANCE_TOKEN_PATH
require_env GITHUB_OUTPUT
require_env GOVERNANCE_ROOT_CONFIG

if [ "$mode" = "apply" ] && [ "${APPLY_CONFIRM:-}" != "apply-reviewed-imports" ]; then
  echo "::error::Set confirm_apply to apply-reviewed-imports before running import apply mode." >&2
  exit 1
fi

cd "$workspace"

scope="${IMPORT_SCOPE:-all}"
nix develop --accept-flake-config --command just build-bootstrap "$GOVERNANCE_ROOT_CONFIG" >/dev/null
nix develop --accept-flake-config --command just github-governance-import-blocks \
  --scope "$scope" \
  --output "$GOVERNANCE_RESULT_ROOT/imports.tf"
cp "$GOVERNANCE_ROOT"/*.tftest.hcl "$GOVERNANCE_RESULT_ROOT"/ 2>/dev/null || true
cp "$GOVERNANCE_ROOT/.terraform.lock.hcl" "$GOVERNANCE_RESULT_ROOT"/

plan_dir="$workspace/.result/github-governance-import-${mode}"
mkdir -p "$plan_dir"

cd "$GOVERNANCE_RESULT_ROOT"
backend_path="$workspace/$BACKEND_CONFIG_FILE"
tofu_bin="$(nix develop --accept-flake-config --command bash -euo pipefail -c 'command -v tofu' | tail -n 1)"
governance_token="$(cat "$GOVERNANCE_TOKEN_PATH")"

run_tofu() {
  env -u AWS_PROFILE -u AWS_DEFAULT_PROFILE GITHUB_TOKEN="$governance_token" "$tofu_bin" "$@"
}

run_tofu init -input=false -reconfigure \
  -backend-config="$(realpath --relative-to="$PWD" "$backend_path")"

plan_bin="$plan_dir/github-governance-import.tfplan"
plan_text="$plan_dir/plan.txt"
plan_stderr="$plan_dir/plan.stderr"
plan_json="$plan_dir/plan.json"
counts_file="$plan_dir/counts.env"

plan_args=(
  -input=false
  -no-color
  -detailed-exitcode
  -out="$plan_bin"
)
if [ "$mode" = "plan" ]; then
  plan_args+=(-lock=false)
fi

set +e
run_tofu plan "${plan_args[@]}" >"$plan_text" 2>"$plan_stderr"
plan_exit=$?
set -e

cat "$plan_text"
cat "$plan_stderr" >&2

if [ "$plan_exit" -eq 1 ]; then
  exit 1
fi

if [ "$plan_exit" -eq 0 ]; then
  echo "changes=false" >> "$GITHUB_OUTPUT"
elif [ "$plan_exit" -eq 2 ]; then
  echo "changes=true" >> "$GITHUB_OUTPUT"
else
  echo "::error::Unexpected tofu plan exit code: $plan_exit" >&2
  exit "$plan_exit"
fi

run_tofu show -json "$plan_bin" >"$plan_json"
echo "binary_plan_path=$(realpath --relative-to="$workspace" "$plan_bin")" >> "$GITHUB_OUTPUT"
echo "text_plan_path=$(realpath --relative-to="$workspace" "$plan_text")" >> "$GITHUB_OUTPUT"
echo "json_plan_path=$(realpath --relative-to="$workspace" "$plan_json")" >> "$GITHUB_OUTPUT"

nix shell --accept-flake-config --inputs-from "$workspace" nixpkgs#python3 --command \
  python3 - "$plan_json" "$GITHUB_OUTPUT" "$counts_file" <<'PY'
import json
import sys

plan_path, output_path, counts_path = sys.argv[1], sys.argv[2], sys.argv[3]
counts = {
    "to_import": 0,
    "to_add": 0,
    "to_change": 0,
    "to_destroy": 0,
    "to_replace": 0,
}

with open(plan_path, encoding="utf-8") as handle:
    plan = json.load(handle)

for change in plan.get("resource_changes", []):
    actions = change.get("change", {}).get("actions", [])
    importing = change.get("change", {}).get("importing") or change.get("importing")
    if importing:
        counts["to_import"] += 1
    if actions == ["no-op"]:
        continue
    if set(actions) >= {"create", "delete"}:
        counts["to_replace"] += 1
    elif "create" in actions:
        counts["to_add"] += 1
    elif "update" in actions:
        counts["to_change"] += 1
    elif "delete" in actions:
        counts["to_destroy"] += 1

with open(output_path, "a", encoding="utf-8") as output:
    for key, value in counts.items():
        print(f"{key}={value}", file=output)

with open(counts_path, "w", encoding="utf-8") as counts_file:
    for key, value in counts.items():
        print(f"{key}={value}", file=counts_file)
PY

# shellcheck disable=SC1090
source "$counts_file"

if [ "$mode" = "apply" ]; then
  if [ "${to_import:-0}" -le 0 ]; then
    echo "::error::Import apply mode requires at least one import action." >&2
    exit 1
  fi

  for key in to_add to_change to_destroy to_replace; do
    value="${!key:-0}"
    if [ "$value" -ne 0 ]; then
      echo "::error::Import apply mode only permits import actions; ${key}=${value}." >&2
      exit 1
    fi
  done

  run_tofu apply -input=false -no-color "$plan_bin"
  echo "Applied reviewed GitHub governance import plan with ${to_import} import(s)."
fi
