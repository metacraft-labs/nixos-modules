{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://metacraft-labs.invalid/schemas/deployment-event.json",
  "title": "DeploymentEvent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deploymentId",
    "correlationId",
    "phase",
    "target",
    "storePaths",
    "timestamps",
    "command"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "deploymentId": {
      "type": "string",
      "minLength": 1
    },
    "correlationId": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "type": "string",
      "enum": [
        "evaluate",
        "build",
        "closure-prefill",
        "cache-push",
        "activate-requested",
        "agent-restore",
        "switch",
        "healthcheck",
        "rollback",
        "complete"
      ]
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "system",
        "kind"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "system": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "server",
            "desktop",
            "vm",
            "container",
            "darwin",
            "unknown"
          ]
        },
        "transport": {
          "type": "string",
          "enum": [
            "cachix-agent",
            "ssh",
            "pull-agent",
            "local",
            "unknown"
          ]
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cache": {
          "type": "string"
        },
        "substituters": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "activateRequestId": {
          "type": "string"
        },
        "controller": {
          "type": "string"
        }
      }
    },
    "storePaths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system"
      ],
      "properties": {
        "system": {
          "type": "string",
          "pattern": "^/nix/store/[0-9a-df-np-sv-z]{32}-.+"
        },
        "derivation": {
          "type": "string"
        },
        "closure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "count",
            "totalBytes",
            "rootHashes"
          ],
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 1
            },
            "totalBytes": {
              "type": "integer",
              "minimum": 0
            },
            "rootHashes": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 32
              }
            }
          }
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startedAt"
      ],
      "properties": {
        "queuedAt": {
          "type": "string",
          "format": "date-time"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "argv": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "running",
            "succeeded",
            "failed",
            "cancelled",
            "skipped"
          ]
        },
        "exitCode": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "message",
        "retryable"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        },
        "details": {
          "type": "object"
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
